<?xml version="1.0" encoding="UTF-8"?>
<ecore:EPackage xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:ecore="http://www.eclipse.org/emf/2002/Ecore" name="aglSecuential" nsURI="model.aglSecuential" nsPrefix="model.aglSecuential">
  <eClassifiers xsi:type="ecore:EClass" name="Ca">
    <eStructuralFeatures xsi:type="ecore:EReference" name="as" lowerBound="1" upperBound="-1"
        eType="#//Cs" eOpposite="#//Cs/aAct"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="an" lowerBound="1" upperBound="-1"
        eType="#//Cn" eOpposite="#//Cn/aAct"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Cs">
    <eStructuralFeatures xsi:type="ecore:EReference" name="aAct" lowerBound="1" eType="#//Ca"
        eOpposite="#//Ca/as"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="an" lowerBound="1" upperBound="-1"
        eType="#//Cn" eOpposite="#//Cn/as"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Cn">
    <eStructuralFeatures xsi:type="ecore:EReference" name="aAct" lowerBound="1" eType="#//Ca"
        eOpposite="#//Ca/an"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="as" lowerBound="1" eType="#//Cs"
        eOpposite="#//Cs/an"/>
  </eClassifiers>
</ecore:EPackage>
