    <eStructuralFeatures xsi:type="ecore:EAttribute" name="zone" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="actSeq" lowerBound="1"
        upperBound="-1" eType="#//MAct" containment="true"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EEnum" name="NodeType">
    <eLiterals name="Action"/>
    <eLiterals name="Decision" value="1"/>
    <eLiterals name="Fork" value="2"/>
    <eLiterals name="Join" value="3"/>
    <eLiterals name="Merge" value="4"/>
    <eLiterals name="Coordinator" value="5"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="MAct">
