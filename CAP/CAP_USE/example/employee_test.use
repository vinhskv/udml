-- $ProjectHeader: use 0.393 Wed, 16 May 2007 14:10:28 +0200 opti $

-- Example illustrating pre- and postconditions

model Employee

-- classes

class Person
attributes
  name : String
  age : Integer
  salary : Real
operations
  raiseSalary(rate : Real) : Real
end

class Company
attributes
  name : String
  location : String
operations
  hire(p : Person)
  fire(p : Person)
end

-- associations

association WorksFor between
  Person[*] role employee
  Company[0..1] role employer
end

-- constraints

constraints

context Person inv ageCheck:
  self.age >= 18

context Person inv checkLocation:
  self.employer.location = 'Hanoi'

context Person::raiseSalary(rate : Real) : Real
  post raiseSalaryPost: 
    salary = salary@pre * (1.0 + rate)
  post resultPost:
    result = salary

context Company::hire(p : Person)
  pre  hirePre1: p.isDefined()
  pre  hirePre2: employee->excludes(p)
  post hirePost: employee->includes(p)

context Company::fire(p : Person)
  pre  firePre:  employee->includes(p)
  post firePost: employee->excludes(p)

@SumConstraint(
          assocCls = enrolments,
          rolePath = course,
          collect = {
            @AttrCond(attr = offering.semester, matchAttr = currentSemester)
          },
          sumAttr = credits,
          maxAttr = maxCredits,
          ifPart = {
            @AttrCond(attr = status, fixAttr = StudentStatus::ENROLLED)
          }
        )


@SumConstraint(
  assocCls = studyRecords,
  rolePath = self,
  collect = {
    @AttrCond(attr = semester, matchAttr = currentSemester)
  },
  sumAttr = studyHours,
  min = 120
)


@SumConstraint(
  assocCls = studyRecords,
  rolePath = self,
  collect = {
    @AttrCond(attr = semester, matchAttr = currentSemester)
  },
  sumAttr = studyHours,
  fixAttr = self.totalStudyHours
)



@SumConstraint(
  assocCls = enrolments,
  rolePath = course,
  collect = {
    @AttrCond(attr = offering.semester, matchAttr = currentSemester)
  },
  sumAttr = credits,
  fixAttr = self.coreCredits
)



@SumConstraint(
  assocCls = Enrolment,
  rolePath = offering,
  collect = {
    @AttrCond(attr = status, matchAttr = status),
    @AttrCond(attr = year,   matchAttr = year)
  },
  sumAttr = credits,
  max = 30
)



@SumConstraint(
           assocCls = Enrolment,
           rolePath = offering,
           collect = {
             @AttrCond(attr = status, matchAttr = status),
             @AttrCond(attr = semester, matchAttr = semester)
           },
           sumAttr = credits,
           min = 15,
           ifPart = {
             @AttrCond(attr = programType, fixStr = HONOURS)
           }
         )



@EligibilityConstraint(
  assocCls    = "Enrolment",
  rolePath      = "course",
  targetAssoc = "enrolments",
  ifPart      = { @AttrCond(attr="year", fixNum=1) },
  collect = {
    @AttrCond(attr="course", attr2="level", minLim=300),
    @AttrCond(attr="approvedByFaculty", fixBool=true, neg=true)
  },
  sumAttr = "1",
  max     = 0
)










