<?xml version="1.0" encoding="UTF-8"?> <?use version="2.4.0"?>
<plugin name="example-plugin" version="0.1" publisher="Dao Huy Hung">
    <actions>
        <action label="Transform Model into CAP"
                icon="resources/filmstrip.png"
                class="org.tzi.use.examplePlugin.ExamplePluginAction"
                tooltip="Transform the currently loaded model into a CAP and save it to disk"
                menu="CAP"
                menuitem="Transform Model into CAP Model"
                toolbaritem="plugins"
                id="org.tzi.use.plugin.examplePlugin.ExamplePluginAction">
        </action>
    </actions>
    <services>
        <service class="org.tzi.use.examplePlugin.ExamplePluginService"
                 id="org.tzi.use.examplePlugin.ExamplePluginService"></service>
    </services>
    <commands>
        <command class="org.tzi.use.examplePlugin.ExamplePluginCmd" id="org.tzi.use.examplePlugin.ExamplePluginCmd"
                 shellcmd="display" label="Display Example Plugin Service"
                 help="Prints a static text for testing"></command>
        <command class="org.tzi.use.examplePlugin.ExamplePluginCmd" id="org.tzi.use.examplePlugin.ExamplePluginCmd"
                 shellcmd="exampleService" label="Display Example Plugin Service"
                 help="Calls the example service"></command>
    </commands>
</plugin>